# Local development can run without Supabase and will use in-memory seed data.
# Production-like environments require these values unless TERMO_ALLOW_MEMORY_STORE=1
# is set explicitly for a throwaway demo.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
TERMO_ABUSE_SECRET=

# Optional local production-readiness check:
# TERMO_REQUIRE_SUPABASE=1 npm run build
TERMO_REQUIRE_SUPABASE=

# Escape hatch for non-production demos only. Do not set this in public production.
TERMO_ALLOW_MEMORY_STORE=
