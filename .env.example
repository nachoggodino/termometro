# Local development can run without Supabase and will use in-memory seed data.
# Vercel preview/production requires these values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional local production-readiness check:
# TERMOMETRO_REQUIRE_SUPABASE=1 npm run build
TERMOMETRO_REQUIRE_SUPABASE=
